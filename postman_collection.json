        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Mengambil response JSON",
                  "var responseData = pm.response.json();",
                  "",
                  "// Menyimpan token secara otomatis ke variabel Collection jika login sukses",
                  "if (responseData.token) {",
                  "    pm.collectionVariables.set(\"token\", responseData.token);",
                  "    console.log(\"Token berhasil diperbarui otomatis di Postman: \" + responseData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"indra123\",\n    \"password\": \"rahasia123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
