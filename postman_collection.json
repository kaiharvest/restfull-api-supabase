    {
      "name": "Todo API",
      "item": [
        {
          "name": "Create Todo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Mengambil response JSON",
                  "var responseData = pm.response.json();",
                  "",
                  "// Menyimpan ID Todo secara otomatis ke variabel Collection jika sukses",
                  "if (responseData.data && responseData.data.id) {",
                  "    pm.collectionVariables.set(\"todoId\", responseData.data.id);",
                  "    console.log(\"ID Todo berhasil disimpan otomatis di Postman: \" + responseData.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "X-API-TOKEN",
                "value": "{{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Belajar Docker\",\n    \"description\": \"Membuat Docker Compose\",\n    \"status\": \"TODO\",\n    \"deadline\": \"2026-07-25\"\n}",
